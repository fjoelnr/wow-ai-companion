# WoW AI Companion – Environment Variables
# Copy this file to .env and adjust values.

# ── LLM Provider ────────────────────────────────────────────────────
# Options: ollama (default, local), openai, openrouter
LLM_PROVIDER=ollama

# ── Ollama (local LLM) ─────────────────────────────────────────────
OLLAMA_MODEL=llama3.2
OLLAMA_FALLBACK_MODEL=mistral-nemo

# ── OpenAI (direct API) ────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── OpenRouter (multi-model gateway) ───────────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=anthropic/claude-sonnet-4
